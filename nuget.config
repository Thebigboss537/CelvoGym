<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/thebigboss537/index.json" />
    <!--
      For local development with CelvoGuard.Client from source:
      dotnet nuget add source ../CelvoGuard/src/CelvoGuard.Client/bin/Debug -n local-celvo
    -->
  </packageSources>
  <packageSourceCredentials>
    <github>
      <add key="Username" value="thebigboss537" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github>
  </packageSourceCredentials>
</configuration>
